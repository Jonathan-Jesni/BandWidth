# .env
# Band Platform Credentials
ARCHITECT_AGENT_ID="your-architect-uuid"
ARCHITECT_API_KEY="your-architect-key"

REVIEWER_AGENT_ID="your-reviewer-uuid"
REVIEWER_API_KEY="your-reviewer-key"

TESTER_AGENT_ID="your-tester-uuid"
TESTER_API_KEY="your-tester-key"

ENGINEER_AGENT_ID="your-engineer-uuid"
ENGINEER_API_KEY="your-engineer-key"

# LLM Providers — BandWidth is cross-model: agents reason on different providers,
# coordinated through Band. Featherless serves open-source inference (DeepSeek);
# AI/ML API serves a hosted frontier model. Both are OpenAI-compatible.
ANTHROPIC_API_KEY="your-claude-key"
FEATHERLESS_API_KEY="your-featherless-key"
AIML_API_KEY="your-aiml-key"

# Model overrides (optional)
FEATHERLESS_MODEL="deepseek-ai/DeepSeek-V4-Pro"
# AIML_MODEL powers the Engineer's fixes + the Architect's plan. gpt-4o-mini is
# cheap for dev, but produces weaker fixes that the stricter DeepSeek reviewer may
# reject (→ escalation). For the FINAL DEMO RECORDING use gpt-4o so fixes converge
# cleanly to a PASS + green tests.
AIML_MODEL="gpt-4o-mini"        # ← set to "gpt-4o" for the demo recording

# Per-role provider overrides (optional): featherless | aimlapi.
# Default topology — Reviewer/Tester on Featherless, Engineer/Architect on AI/ML API.
# If AIML_API_KEY is unset, those roles fall back to Featherless automatically.
REVIEWER_PROVIDER="featherless"
TESTER_PROVIDER="featherless"
ENGINEER_PROVIDER="aimlapi"
ARCHITECT_PROVIDER="aimlapi"

# GitHub integration
GITHUB_TOKEN="your-github-pat"
GITHUB_WEBHOOK_SECRET="your-webhook-secret"

# Feature flags (default off). Each is a code-execution / write-access risk —
# enable deliberately. Truthy = 1/true/yes/on.
ENABLE_TEST_EXECUTION="0"   # Tester runs real pytest in a sandboxed subprocess
ENABLE_AUTO_FIX="0"         # Engineer pushes fix commits to the PR branch